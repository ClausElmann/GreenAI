    "command_or_query": "path to Command.cs or Query.cs",
    "handler": "path to Handler.cs",
    "endpoint": "path to Endpoint.cs (null if Blazor-only)",
    "sql_files": "array of embedded .sql paths",
    "validator": "path to Validator.cs (null if no validation)",
    "ui_page": "path to .razor page if feature has UI (null if API-only)",
