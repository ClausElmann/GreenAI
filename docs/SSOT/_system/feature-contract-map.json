    "if_route_exists": [
      "endpoint must not be null"
    ],
    "if_endpoint_is_null": [
      "tests.e2e must not be null (FEATURE-003)"
    ],
    "if_auth_is_profile_or_authenticated": [
      "IRequireAuthentication must be in pipeline_markers"
    ],
    "if_sql_files_has_more_than_1_write": [
      "ExecuteInTransactionAsync note must be present"
    ],
    "test_coverage_minimum": "integration test required for every feature with a route; e2e required for every Blazor-only feature"
  }
}
