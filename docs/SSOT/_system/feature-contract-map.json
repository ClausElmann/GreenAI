{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "green-ai feature contract map — every implemented feature with its red threads, handler, endpoint, SQL files, tests, and UI component. Machine-readable. Update when new feature is added.",
  "version": "1.0.0",
  "last_updated": "2026-04-06",
  "ssot_source": "docs/SSOT/_system/feature-contract-map.json",
  "contract_schema": {
    "id": "unique feature id (snake_case)",
    "domain": "Auth | CustomerAdmin | Identity | Localization | System | Api",
    "route": "HTTP method + path",
    "red_threads": "array of bound red_thread ids from RED_THREAD_REGISTRY.md",
    "command_or_query": "path to Command.cs or Query.cs",
    "handler": "path to Handler.cs",
    "endpoint": "path to Endpoint.cs (null if Blazor-only)",
    "sql_files": "array of embedded .sql paths",
    "validator": "path to Validator.cs (null if no validation)",
    "ui_page": "path to .razor page if feature has UI (null if API-only)",
    "tests": {
      "integration": "path to integration test class",
      "unit": "path to unit test class (null if covered by integration)"
    },
    "auth": "none | authenticated | profile",
    "pipeline_markers": "array of pipeline marker interfaces on Command/Query"
  },
