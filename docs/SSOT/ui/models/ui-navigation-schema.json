{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "green-ai UI navigation model — routes, auth requirements, breadcrumbs, role visibility. Machine-readable. Updated when new pages are added.",
  "version": "3.0.0",
  "last_updated": "2026-04-06",
  "decisions_locked": "2026-04-06",
  "ssot_source": "docs/SSOT/ui/models/ui-navigation-schema.json",
  "architecture_ref": "docs/SSOT/ui/ui-architecture-decisions.md",

  "routing_decisions": {
    "root_authenticated": "redirect to /broadcasting (single customer+profile) OR /select-customer (multiple)",
    "root_unauthenticated": "redirect to /login",
    "dashboard_status": "DEPRECATED — redirects to /broadcasting",
    "primary_entry_point": "/broadcasting",
    "login_layout": "EmptyLayout — DO NOT CHANGE",
    "select_customer_layout": "EmptyLayout — no chrome until context is set",
    "select_profile_layout": "EmptyLayout — no chrome until context is set"
  },

  "wizard_draft_policy": {
    "auto_save_required": true,
    "save_triggers": ["step_change", "explicit_back", "route_away"],
    "save_target": "/drafts",
    "scope": "safe recovery only — not live sync",
    "out_of_scope": ["debounced_autosave_while_typing", "collaborative_sync", "conflict_resolution"]
  },

  "auth_requirements": {
    "none": "Public — no token required",
    "authenticated": "ICurrentUser.UserId must be set (BlazorPrincipalHolder.Set() called)",
    "tenant": "ICurrentUser.CustomerId must be set (JWT claim)",
    "profile": "ICurrentUser.ProfileId must be set (JWT claim)"
  },

  "layouts": {
    "EmptyLayout": "Login, OAuth, select-customer, select-profile — no chrome",
    "MainLayout": "All authenticated profile-scoped pages — TopBar + OverlayNav",
    "WizardLayout": "Send flow (/send/wizard) — TopBar minimal + progress bar"
  },

  "pages": [
    {
      "id": "root",
      "route": "/",
      "status": "deprecated_redirect",
      "component": "Components/Pages/Home.razor",
      "layout": "none",
      "auth": "none",
      "redirect_authenticated": "/broadcasting",
      "redirect_unauthenticated": "/login",
      "breadcrumb": []
    },
    {
      "id": "login",
      "route": "/login",
      "status": "implemented",
      "component": "Features/Auth/Login/LoginPage.razor",
      "layout": "EmptyLayout",
      "auth": "none",
      "breadcrumb": []
    },
    {
      "id": "select_customer",
      "route": "/select-customer",
      "status": "implemented",
      "component": "Components/Pages/Auth/SelectCustomerPage.razor",
      "layout": "EmptyLayout",
      "auth": "authenticated",
      "breadcrumb": []
    },
    {
      "id": "select_profile",
      "route": "/select-profile",
      "status": "implemented",
      "component": "Components/Pages/Auth/SelectProfilePage.razor",
      "layout": "EmptyLayout",
      "auth": "authenticated",
      "breadcrumb": []
    },
    {
      "id": "dashboard",
      "route": "/dashboard",
      "status": "deprecated_redirect",
      "component": "Components/Pages/DashboardPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "redirect_to": "/broadcasting",
      "breadcrumb": []
    },
    {
      "id": "broadcasting",
      "route": "/broadcasting",
      "status": "implemented",
      "component": "Components/Pages/Broadcasting/BroadcastingHubPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": ["any_authenticated"],
      "breadcrumb": [{ "text": "Broadcasting", "href": null }],
      "description": "Primary entry point — broadcasting hub with send methods"
    },
    {
      "id": "send_wizard",
      "route": "/send/wizard",
      "status": "implemented",
      "component": "Components/Pages/Broadcasting/SendWizardPage.razor",
      "layout": "WizardLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": [],
      "draft_auto_save": true,
      "draft_save_triggers": ["step_change", "explicit_back", "route_away"],
      "breadcrumb": [],
      "description": "Multi-step send flow — WizardLayout",
      "query_params": ["scenario"]
    },
    {
      "id": "status",
      "route": "/status",
      "status": "implemented",
      "component": "Components/Pages/Broadcasting/StatusPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": ["any_authenticated"],
      "breadcrumb": [{ "text": "Status", "href": null }],
      "tabs": ["Sendt", "Planlagt", "Fejlet"]
    },
    {
      "id": "status_detail",
      "route": "/status/{id:int}",
      "status": "implemented",
      "component": "Components/Pages/Broadcasting/StatusDetailPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": [],
      "breadcrumb": [
        { "text": "Status", "href": "/status" },
        { "text": "Detaljer", "href": null }
      ]
    },
    {
      "id": "drafts",
      "route": "/drafts",
      "status": "implemented",
      "component": "Components/Pages/Broadcasting/DraftsPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": ["any_authenticated"],
      "breadcrumb": [{ "text": "Kladder", "href": null }]
    },
    {
      "id": "user_profile",
      "route": "/user/profile",
      "status": "implemented",
      "component": "Components/Pages/UserSelfService/UserProfilePage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": [],
      "nav_visible_for": ["any_authenticated"],
      "breadcrumb": [{ "text": "Min profil", "href": null }]
    },
    {
      "id": "customer_admin",
      "route": "/customer-admin",
      "status": "implemented",
      "component": "Components/Pages/CustomerAdmin/Index.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["CustomerSetup", "ManageUsers", "ManageProfiles"],
      "nav_visible_for": ["CustomerSetup", "ManageUsers", "ManageProfiles"],
      "breadcrumb": [{ "text": "Kundestyre", "href": null }],
      "tabs": ["Indstillinger", "Brugere", "Profiler"]
    },
    {
      "id": "customer_admin_user_detail",
      "route": "/customer-admin/users/{UserId:int}",
      "status": "implemented",
      "component": "Components/Pages/CustomerAdmin/UserDetail.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["CustomerSetup", "ManageUsers"],
      "nav_visible_for": [],
      "breadcrumb": [
        { "text": "Kundestyre", "href": "/customer-admin" },
        { "text": "Bruger", "href": null }
      ]
    },
    {
      "id": "customer_admin_profile_detail",
      "route": "/customer-admin/profiles/{ProfileId:int}",
      "status": "implemented",
      "component": "Components/Pages/CustomerAdmin/ProfileDetail.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["CustomerSetup", "ManageProfiles"],
      "nav_visible_for": [],
      "breadcrumb": [
        { "text": "Kundestyre", "href": "/customer-admin" },
        { "text": "Profil", "href": null }
      ]
    },
    {
      "id": "admin_users",
      "route": "/admin/users",
      "status": "implemented",
      "component": "Components/Pages/AdminLight/AdminUserListPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["SuperAdmin", "ManageUsers"],
      "nav_visible_for": ["SuperAdmin", "ManageUsers"],
      "breadcrumb": [
        { "text": "Admin", "href": "/admin/users" },
        { "text": "Brugere", "href": null }
      ]
    },
    {
      "id": "admin_settings",
      "route": "/admin/settings",
      "status": "implemented",
      "component": "Components/Pages/AdminLight/AdminSettingsPage.razor",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["SuperAdmin"],
      "nav_visible_for": ["SuperAdmin"],
      "breadcrumb": [
        { "text": "Admin", "href": "/admin/settings" },
        { "text": "Indstillinger", "href": null }
      ]
    },
    {
      "id": "admin_super",
      "route": "/admin/super",
      "status": "planned",
      "layout": "MainLayout",
      "auth": "profile",
      "required_roles": ["SuperAdmin"],
      "nav_visible_for": ["SuperAdmin"],
      "breadcrumb": [
        { "text": "Admin", "href": "/admin/super" },
        { "text": "Super", "href": null }
      ]
    }
  ],

  "nav_rules": {
    "unauthenticated": "redirect to /login",
    "authenticated_no_customer": "redirect to /select-customer",
    "authenticated_no_profile": "redirect to /select-profile",
    "fully_authenticated": "allow profile-scoped pages",
    "role_check_failure": "redirect to /broadcasting (never 403 in UI)"
  },

  "overlay_nav_sections": [
    {
      "section": "Primær",
      "items": [
        { "label": "nav.Broadcasting", "route": "/broadcasting", "roles": [] },
        { "label": "nav.Status",       "route": "/status",       "roles": [] },
        { "label": "nav.Drafts",       "route": "/drafts",       "roles": [] }
      ]
    },
    {
      "section": "Konto",
      "items": [
        { "label": "nav.UserProfile",   "route": "/user/profile",   "roles": [] },
        { "label": "nav.CustomerAdmin", "route": "/customer-admin", "roles": ["CustomerSetup", "ManageUsers", "ManageProfiles"] }
      ]
    },
    {
      "section": "Admin",
      "roles_required_for_section": ["SuperAdmin", "ManageUsers"],
      "items": [
        { "label": "nav.AdminUsers",    "route": "/admin/users",    "roles": ["SuperAdmin", "ManageUsers"] },
        { "label": "nav.AdminSettings", "route": "/admin/settings", "roles": ["SuperAdmin"] },
        { "label": "nav.SuperAdmin",    "route": "/admin/super",    "roles": ["SuperAdmin"] }
      ]
    }
  ]
}
