@* BroadcastTable — reusable table for status list page tabs *@
@using GreenAi.Api.Mocks
@using GreenAi.Api.SharedKernel.Localization

<MudTable T="BroadcastMock"
          Items="Items"
          Dense="true"
          Hover="true"
          OnRowClick='@(e => { if (e.Item is not null) OnRowClick.InvokeAsync(e.Item.Id); })'
          RowClass="cursor-pointer"
          data-testid="status-list-table">
    <HeaderContent>
        <MudTh>@Loc.Get("page.statusList.ColSubject")</MudTh>
        <MudTh>@Loc.Get("page.statusList.ColProfile")</MudTh>
        <MudTh>@Loc.Get("page.statusList.ColMethod")</MudTh>
        <MudTh Class="ga-col-numeric">@Loc.Get("page.statusList.ColRecipients")</MudTh>
        @if (ShowScheduled)
        {
            <MudTh>@Loc.Get("page.statusList.ColScheduled")</MudTh>
        }
        else if (ShowFailed)
        {
            <MudTh Class="ga-col-numeric">@Loc.Get("page.statusList.ColFailed")</MudTh>
            <MudTh Class="ga-col-numeric">@Loc.Get("page.statusList.ColDeliveryRate")</MudTh>
        }
        else
        {
            <MudTh Class="ga-col-numeric">@Loc.Get("page.statusList.ColDelivered")</MudTh>
        }
        <MudTh>@Loc.Get("page.statusList.ColCreated")</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Emne">
            <MudText Typo="Typo.body2" Class="ga-text-cell-truncate">
                @context.Subject
            </MudText>
        </MudTd>
        <MudTd DataLabel="Profil">
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ga-chip-reset">
                @context.Profile
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Metode">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @MockData.GetSendMethodLabel(MockData.GetSendMethodKey(context.Id))
            </MudText>
        </MudTd>
        <MudTd DataLabel="Modtagere" Class="ga-col-numeric">
            @context.Recipients.ToString("N0")
        </MudTd>
        @if (ShowScheduled)
        {
            <MudTd DataLabel="Planlagt">
                <MudText Typo="Typo.caption" Color="Color.Info">
                    @(context.ScheduledAt.HasValue
                        ? context.ScheduledAt.Value.ToString("d. MMM HH:mm")
                        : "—")
                </MudText>
            </MudTd>
        }
        else if (ShowFailed)
        {
            <MudTd DataLabel="Fejlede" Class="ga-col-numeric">
                <MudText Typo="Typo.body2" Color="Color.Error">
                    @context.FailedCount.ToString("N0")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Leveringsrate" Class="ga-col-numeric">
                @{
                    var rate = context.Recipients > 0
                        ? (int)((context.Delivered * 100.0) / context.Recipients)
                        : 0;
                    var rateClass = rate >= 80 ? "ga-rate-good"
                                  : rate >= 50 ? "ga-rate-medium"
                                  : "ga-rate-bad";
                }
                <MudText Typo="Typo.body2" Class="@rateClass">
                    @rate%
                </MudText>
            </MudTd>
        }
        else
        {
            <MudTd DataLabel="Leveret" Class="ga-col-numeric">
                <MudText Typo="Typo.body2" Color="Color.Success">
                    @context.Delivered.ToString("N0")
                </MudText>
            </MudTd>
        }
        <MudTd DataLabel="Oprettet">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @context.CreatedAt.ToString("d. MMM HH:mm")
            </MudText>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <div class="ga-empty-state">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Class="ga-icon-xl-faded" />
            <MudText Typo="Typo.body2">@Loc.Get("page.statusList.EmptyResult")</MudText>
        </div>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BroadcastMock> Items  { get; set; } = [];
    [Parameter, EditorRequired] public EventCallback<int>           OnRowClick { get; set; }
    [Parameter, EditorRequired] public ILocalizationContext         Loc    { get; set; } = null!;
    [Parameter] public bool ShowScheduled { get; set; }
    [Parameter] public bool ShowFailed    { get; set; }

    // Prevent re-renders when Items reference and bool params haven't changed.
    // StatusPage creates new list instances on every ApplyFilter(), so reference
    // equality is a reliable signal. Called after SetParametersAsync — params are current.
    private IReadOnlyList<BroadcastMock>? _prevItems;
    private bool _prevShowScheduled;
    private bool _prevShowFailed;

    protected override bool ShouldRender()
    {
        if (!ReferenceEquals(_prevItems, Items)
            || _prevShowScheduled != ShowScheduled
            || _prevShowFailed    != ShowFailed)
        {
            _prevItems         = Items;
            _prevShowScheduled = ShowScheduled;
            _prevShowFailed    = ShowFailed;
            return true;
        }
        return false;
    }
}
