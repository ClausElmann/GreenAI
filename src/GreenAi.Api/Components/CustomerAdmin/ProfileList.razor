@using GreenAi.Api.Features.CustomerAdmin.GetProfiles
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject ILocalizationContext Loc

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.subtitle1">@Profiles.Count profil(er)</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Size="Size.Small"
               OnClick="CreateProfile"
               data-testid="create-profile">
        @Loc.Get("profile.CreateButton")
    </MudButton>
</MudStack>

<MudTable Items="Profiles" Dense="true" Hover="true" data-testid="profile-table">
    <HeaderContent>
        <MudTh>@Loc.Get("shared.NameLabel")</MudTh>
        <MudTh>@Loc.Get("shared.StatusLabel")</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Loc.Get("shared.NameLabel")">
            <MudLink Href="@("/customer-admin/profiles/" + context.Id)">@context.Name</MudLink>
        </MudTd>
        <MudTd DataLabel="@Loc.Get("shared.StatusLabel")">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? Loc.Get("shared.Active") : Loc.Get("shared.Inactive"))
            </MudChip>
        </MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="0">
                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                               Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo("/customer-admin/profiles/" + context.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               OnClick="() => ConfirmDeleteAsync(context)" />
            </MudStack>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.Get("profile.NoRecords")</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public List<ProfileRow> Profiles { get; set; } = null!;
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private void CreateProfile() => Snackbar.Add(Loc.Get("profile.CreateNotImplemented"), Severity.Info);

    private async Task ConfirmDeleteAsync(ProfileRow profile)
    {
        var confirmed = await Dialog.ShowMessageBox(
            Loc.Get("profile.DeleteTitle"),
            Loc.Get("shared.DeleteConfirmMessage", profile.Name),
            yesText: Loc.Get("shared.DeleteButton"), cancelText: Loc.Get("shared.CancelButton"));

        if (confirmed == true)
        {
            await OnDelete.InvokeAsync(profile.Id);
            Snackbar.Add(Loc.Get("shared.DeletedMessage", profile.Name), Severity.Success);
        }
    }
}
