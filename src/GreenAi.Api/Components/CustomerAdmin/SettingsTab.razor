@using GreenAi.Api.Features.CustomerAdmin.GetCustomerSettings
@inject ISnackbar Snackbar
@inject ILocalizationContext Loc

<MudForm @ref="_form">
    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_name"
                          Label="@Loc.Get("shared.NameLabel")"
                          Variant="Variant.Outlined"
                          Required="true"
                          Class="mb-3"
                          UserAttributes="@(new Dictionary<string, object>{ ["data-testid"] = "settings-customer-name" })" />
        </MudItem>
        <MudItem xs="12">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       Disabled="_saving"
                       OnClick="SaveAsync"
                       data-testid="settings-save">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @Loc.Get("settings.SaveButton")
            </MudButton>
        </MudItem>
    </MudGrid>
</MudForm>

@code {
    [Parameter, EditorRequired] public int CustomerId { get; set; }
    [Parameter, EditorRequired] public string CustomerName { get; set; } = string.Empty;

    private MudForm? _form;
    private bool _saving;
    private string _name = string.Empty;

    protected override void OnParametersSet() => _name = CustomerName;

    private async Task SaveAsync()
    {
        await _form!.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        // TODO: await Mediator.Send(new UpdateCustomerSettingsCommand(CustomerId, _name));
        _saving = false;
        Snackbar.Add(Loc.Get("settings.SavedMessage"), Severity.Success);
    }
}
