@using GreenAi.Api.Features.CustomerAdmin.GetUsers
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject ILocalizationContext Loc

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
    <MudText Typo="Typo.subtitle1">@Users.Count bruger(e)</MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               Size="Size.Small"
               OnClick="CreateUser"
               data-testid="create-user">
        @Loc.Get("feature.user.CreateButton")
    </MudButton>
</MudStack>

<MudTable Items="Users" Dense="true" Hover="true" data-testid="user-table">
    <HeaderContent>
        <MudTh>@Loc.Get("shared.EmailLabel")</MudTh>
        <MudTh>@Loc.Get("shared.StatusLabel")</MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="@Loc.Get("shared.EmailLabel")">
            <MudLink Href="@("/customer-admin/users/" + context.Id)">@context.Email</MudLink>
        </MudTd>
        <MudTd DataLabel="@Loc.Get("shared.StatusLabel")">
            <MudChip T="string"
                     Size="Size.Small"
                     Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? Loc.Get("shared.Active") : Loc.Get("shared.Inactive"))
            </MudChip>
        </MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="0">
                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                               Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo("/customer-admin/users/" + context.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               OnClick="() => ConfirmDeleteAsync(context)" />
            </MudStack>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.Get("feature.user.NoRecords")</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    [Parameter, EditorRequired] public List<UserRow> Users { get; set; } = null!;
    [Parameter] public EventCallback<int> OnDelete { get; set; }

    private void CreateUser() => Snackbar.Add(Loc.Get("feature.user.CreateNotImplemented"), Severity.Info);

    private async Task ConfirmDeleteAsync(UserRow user)
    {
        var confirmed = await Dialog.ShowMessageBox(
            Loc.Get("feature.user.DeleteTitle"),
            Loc.Get("shared.DeleteConfirmFormat", user.Email),
            yesText: Loc.Get("shared.DeleteButton"), cancelText: Loc.Get("shared.CancelButton"));

        if (confirmed == true)
        {
            await OnDelete.InvokeAsync(user.Id);
            Snackbar.Add(Loc.Get("shared.DeletedMessage", user.Email), Severity.Success);
        }
    }
}
