@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using GreenAi.Api.Features.Auth.GetProfileContext
@using GreenAi.Api.SharedKernel.State
@using GreenAi.Api.SharedKernel.Navigation
@using GreenAi.Api.SharedKernel.Permissions
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser
@inject IMediator Mediator
@inject BlazorPrincipalHolder PrincipalHolder
@inject AppState AppState
@inject IPermissionService Permissions

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@* Override MudBlazor default palette; must come AFTER <MudThemeProvider /> in DOM
   order so our :root variables take precedence over the default theme injection. *@
<style id="greenai-palette-override">
    /* All hex values come from design-tokens.css (--color-*) — single source of truth.
       MudBlazor-specific darken/lighten variants (hover states) are kept here as
       they are internal MudBlazor states with no semantic meaning beyond the component. */
    :root {
        /* Primary */
        --mud-palette-primary:              var(--color-primary);
        --mud-palette-primary-text:         white;
        --mud-palette-primary-darken:       var(--color-primary-hover);
        --mud-palette-primary-lighten:      #60A5FA;  /* MudBlazor focus ring tint */
        --mud-palette-primary-hover:        rgba(37,99,235,.07);
        --mud-palette-secondary:            var(--color-text-secondary);
        --mud-palette-secondary-text:       white;
        --mud-palette-secondary-darken:     #4B5563;
        --mud-palette-secondary-lighten:    var(--color-text-disabled);
        /* Surfaces */
        --mud-palette-surface:              var(--color-bg-surface);
        --mud-palette-background:           var(--color-bg-main);
        --mud-palette-background-grey:      #F3F4F6;  /* MudBlazor table alt-row tint */
        --mud-palette-overlay-dark:         rgba(16,24,40,.5);
        /* Borders */
        --mud-palette-divider:              var(--color-border-light);
        --mud-palette-divider-light:        rgba(229,231,235,.5);
        /* Text */
        --mud-palette-text-primary:         var(--color-text-primary);
        --mud-palette-text-secondary:       var(--color-text-secondary);
        --mud-palette-text-disabled:        var(--color-text-disabled);
        --mud-palette-action-default:       var(--color-text-secondary);
        --mud-palette-action-hover-opacity: 0.06;
        --mud-palette-action-disabled:      var(--color-text-disabled);
        /* Success */
        --mud-palette-success:              var(--color-success);
        --mud-palette-success-text:         white;
        --mud-palette-success-darken:       #15803D;  /* MudBlazor success hover */
        /* Warning — pending/caution, never primary actions */
        --mud-palette-warning:              var(--color-warning);
        --mud-palette-warning-text:         white;
        --mud-palette-warning-darken:       #B45309;  /* MudBlazor warning hover */
        /* Error — errors and failures ONLY */
        --mud-palette-error:                var(--color-error);
        --mud-palette-error-text:           white;
        --mud-palette-error-darken:         #B91C1C;  /* MudBlazor error hover */
        /* Info */
        --mud-palette-info:                 var(--color-info);
        --mud-palette-info-text:            white;
        --mud-palette-info-darken:          #0369A1;  /* MudBlazor info hover */
        --mud-default-borderradius:         8px;
        --mud-typography-body1-size:        .875rem;
        --mud-typography-body2-size:        .875rem;
    }
</style>

<MudLayout data-testid="layout-root">
    <TopBar />
    <OverlayNav />
    <CommandPalette />

    <MudMainContent>
        <div class="main-content-inner">
            @* Guard: body only renders after EnsureLoadedAsync completes.
               Raw label keys never appear in the DOM — all Loc.Get() calls return
               translated values on first body render. Tests that wait for any
               page element implicitly confirm labels are loaded. *@
            @if (_labelsReady)
            {
                @Body
            }
        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    private bool _labelsReady;

    protected override async Task OnInitializedAsync()
    {
        // Load labels always — fallback to Danish (1) for unauthenticated users.
        // _labelsReady is set AFTER the await so @Body only renders once labels
        // are in the dictionary. Raw keys never appear in the DOM.
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
        _labelsReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        PrincipalHolder.Set(authState.User);

        var result = await Mediator.Send(new GetProfileContextQuery());
        if (result.IsSuccess)
            AppState.SetActiveContext(result.Value!.ProfileDisplayName, result.Value!.CustomerName);

        // Resolve role flags once per circuit — stored in AppState for CommandPalette
        var userId       = CurrentUser.UserId;
        var isSuperAdmin = await Permissions.IsUserSuperAdminAsync(userId);
        var userRoles    = new HashSet<string>(StringComparer.Ordinal);
        if (isSuperAdmin) userRoles.Add(UserRoleNames.SuperAdmin);
        foreach (var role in new[] { UserRoleNames.ManageUsers, UserRoleNames.ManageProfiles, UserRoleNames.CustomerSetup })
            if (await Permissions.DoesUserHaveRoleAsync(userId, role))
                userRoles.Add(role);

        var allowedItems = NavCatalog.All
            .Where(item => item.RequiredAnyRole.Length == 0
                        || item.RequiredAnyRole.Any(r => userRoles.Contains(r)))
            .ToList();
        AppState.SetAllowedNavItems(allowedItems);
    }
}

