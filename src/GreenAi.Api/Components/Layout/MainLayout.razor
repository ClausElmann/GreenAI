@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using GreenAi.Api.Features.Auth.GetProfileContext
@using GreenAi.Api.SharedKernel.State
@using GreenAi.Api.SharedKernel.Navigation
@using GreenAi.Api.SharedKernel.Permissions
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser
@inject IMediator Mediator
@inject BlazorPrincipalHolder PrincipalHolder
@inject AppState AppState
@inject IPermissionService Permissions

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@* Override MudBlazor default palette; must come AFTER <MudThemeProvider /> in DOM
   order so our :root variables take precedence over the default theme injection. *@
<style id="greenai-palette-override">
    :root {
        --mud-palette-primary:              #0B5FFF;
        --mud-palette-primary-text:         #FFFFFF;
        --mud-palette-primary-darken:       #084FD6;
        --mud-palette-primary-lighten:      #4B87FF;
        --mud-palette-primary-hover:        rgba(11,95,255,.06);
        --mud-palette-secondary:            #4B5B6B;
        --mud-palette-secondary-text:       #FFFFFF;
        --mud-palette-secondary-darken:     #2E3B4B;
        --mud-palette-secondary-lighten:    #8A9BAC;
        --mud-palette-surface:              #FFFFFF;
        --mud-palette-background:           #F7F9FC;
        --mud-palette-background-grey:      #F1F4F8;
        --mud-palette-overlay-dark:         rgba(16,24,40,.5);
        --mud-palette-divider:              #D7DEE7;
        --mud-palette-divider-light:        rgba(215,222,231,.5);
        --mud-palette-text-primary:         #16202A;
        --mud-palette-text-secondary:       #4B5B6B;
        --mud-palette-text-disabled:        #9AA0A6;
        --mud-palette-action-default:       #4B5B6B;
        --mud-palette-action-hover-opacity: 0.06;
        --mud-palette-action-disabled:      #9AA0A6;
        --mud-palette-success:              #117A37;
        --mud-palette-success-text:         #FFFFFF;
        --mud-palette-success-darken:       #0A5728;
        --mud-palette-warning:              #A15C00;
        --mud-palette-warning-text:         #FFFFFF;
        --mud-palette-warning-darken:       #7A4500;
        --mud-palette-error:                #B42318;
        --mud-palette-error-text:           #FFFFFF;
        --mud-palette-error-darken:         #8A1910;
        --mud-palette-info:                 #005E7A;
        --mud-palette-info-text:            #FFFFFF;
        --mud-palette-info-darken:          #00445A;
    }
</style>

<MudLayout>
    <TopBar />
    <OverlayNav />
    <CommandPalette />

    <MudMainContent>
        <div class="main-content-inner">
            @* Guard: body only renders after EnsureLoadedAsync completes.
               Raw label keys never appear in the DOM — all Loc.Get() calls return
               translated values on first body render. Tests that wait for any
               page element implicitly confirm labels are loaded. *@
            @if (_labelsReady)
            {
                @Body
            }
        </div>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    private bool _labelsReady;

    protected override async Task OnInitializedAsync()
    {
        // Load labels always — fallback to Danish (1) for unauthenticated users.
        // _labelsReady is set AFTER the await so @Body only renders once labels
        // are in the dictionary. Raw keys never appear in the DOM.
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
        _labelsReady = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        PrincipalHolder.Set(authState.User);

        var result = await Mediator.Send(new GetProfileContextQuery());
        if (result.IsSuccess)
            AppState.SetActiveContext(result.Value!.ProfileDisplayName, result.Value!.CustomerName);

        // Resolve role flags once per circuit — stored in AppState for CommandPalette
        var userId       = CurrentUser.UserId;
        var isSuperAdmin = await Permissions.IsUserSuperAdminAsync(userId);
        var userRoles    = new HashSet<string>(StringComparer.Ordinal);
        if (isSuperAdmin) userRoles.Add(UserRoleNames.SuperAdmin);
        foreach (var role in new[] { UserRoleNames.ManageUsers, UserRoleNames.ManageProfiles, UserRoleNames.CustomerSetup })
            if (await Permissions.DoesUserHaveRoleAsync(userId, role))
                userRoles.Add(role);

        var allowedItems = NavCatalog.All
            .Where(item => item.RequiredAnyRole.Length == 0
                        || item.RequiredAnyRole.Any(r => userRoles.Contains(r)))
            .ToList();
        AppState.SetAllowedNavItems(allowedItems);
    }
}

