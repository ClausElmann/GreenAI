@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using GreenAi.Api.Features.Auth.GetProfileContext
@using GreenAi.Api.SharedKernel.State
@using GreenAi.Api.SharedKernel.Navigation
@using GreenAi.Api.SharedKernel.Permissions
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser
@inject IMediator Mediator
@inject BlazorPrincipalHolder PrincipalHolder
@inject AppState AppState
@inject IPermissionService Permissions

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <TopBar />
    <OverlayNav />
    <CommandPalette />

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-6 pb-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        // Load labels always — fallback to Danish (1) for unauthenticated users
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        PrincipalHolder.Set(authState.User);

        var result = await Mediator.Send(new GetProfileContextQuery());
        if (result.IsSuccess)
            AppState.SetActiveContext(result.Value!.ProfileDisplayName, result.Value!.CustomerName);

        // Resolve role flags once per circuit — stored in AppState for CommandPalette
        var userId       = CurrentUser.UserId;
        var isSuperAdmin = await Permissions.IsUserSuperAdminAsync(userId);
        var userRoles    = new HashSet<string>(StringComparer.Ordinal);
        if (isSuperAdmin) userRoles.Add(UserRoleNames.SuperAdmin);
        foreach (var role in new[] { UserRoleNames.ManageUsers, UserRoleNames.ManageProfiles, UserRoleNames.CustomerSetup })
            if (await Permissions.DoesUserHaveRoleAsync(userId, role))
                userRoles.Add(role);

        var allowedItems = NavCatalog.All
            .Where(item => item.RequiredAnyRole.Length == 0
                        || item.RequiredAnyRole.Any(r => userRoles.Contains(r)))
            .ToList();
        AppState.SetAllowedNavItems(allowedItems);
    }
}

