@* WizardLayout — minimal shell for /send/wizard.
   Full wizard implementation is deferred (step logic not yet built).
   Uses EmptyLayout-style chrome: TopBar minimal, no OverlayNav.
*@
@inherits LayoutComponentBase
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" data-testid="wizard-app-bar">
        <MudText Typo="Typo.h6" Class="ml-3">GreenAI</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pt-8 pb-8">
            @* Guard: body only renders after labels are loaded — no raw keys ever visible *@
            @if (_labelsReady)
            {
                @Body
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _labelsReady;

    protected override async Task OnInitializedAsync()
    {
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
        _labelsReady = true;
    }

    // OnAfterRenderAsync not needed — labels are guarded by @if (_labelsReady) on @Body
}
