@* WizardLayout — minimal shell for /send/wizard.
   Full wizard implementation is deferred (step logic not yet built).
   Uses EmptyLayout-style chrome: TopBar minimal, no OverlayNav.
*@
@inherits LayoutComponentBase
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@* Override MudBlazor default palette — see MainLayout.razor for explanation. *@
<style id="greenai-palette-override">
    :root {
        --mud-palette-primary:              #0B5FFF;
        --mud-palette-primary-text:         #FFFFFF;
        --mud-palette-secondary:            #4B5B6B;
        --mud-palette-secondary-text:       #FFFFFF;
        --mud-palette-text-secondary:       #4B5B6B;
        --mud-palette-text-disabled:        #9AA0A6;
        --mud-palette-surface:              #FFFFFF;
        --mud-palette-background:           #F7F9FC;
        --mud-palette-error:                #B42318;
        --mud-palette-error-text:           #FFFFFF;
        --mud-palette-warning:              #A15C00;
        --mud-palette-warning-text:         #FFFFFF;
        --mud-palette-success:              #117A37;
        --mud-palette-success-text:         #FFFFFF;
    }
</style>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" data-testid="wizard-app-bar">
        <MudText Typo="Typo.h6" Class="ml-3">GreenAI</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pt-8 pb-8">
            @* Guard: body only renders after labels are loaded — no raw keys ever visible *@
            @if (_labelsReady)
            {
                @Body
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _labelsReady;

    protected override async Task OnInitializedAsync()
    {
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
        _labelsReady = true;
    }

    // OnAfterRenderAsync not needed — labels are guarded by @if (_labelsReady) on @Body
}
