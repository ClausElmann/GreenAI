@* WizardLayout — minimal shell for /send/wizard.
   Full wizard implementation is deferred (step logic not yet built).
   Uses EmptyLayout-style chrome: TopBar minimal, no OverlayNav.
*@
@inherits LayoutComponentBase
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
@* Override MudBlazor default palette — see MainLayout.razor for explanation. *@
<style id="greenai-palette-override">
    /* Derives from design-tokens.css (--color-*) — single source of truth. */
    :root {
        --mud-palette-primary:              var(--color-primary);
        --mud-palette-primary-text:         white;
        --mud-palette-secondary:            var(--color-text-secondary);
        --mud-palette-secondary-text:       white;
        --mud-palette-text-primary:         var(--color-text-primary);
        --mud-palette-text-secondary:       var(--color-text-secondary);
        --mud-palette-text-disabled:        var(--color-text-disabled);
        --mud-palette-surface:              var(--color-bg-surface);
        --mud-palette-background:           var(--color-bg-main);
        --mud-palette-error:                var(--color-error);
        --mud-palette-error-text:           white;
        --mud-palette-warning:              var(--color-warning);
        --mud-palette-warning-text:         white;
        --mud-palette-success:              var(--color-success);
        --mud-palette-success-text:         white;
    }
</style>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true" data-testid="wizard-app-bar">
        <MudText Typo="Typo.h6" Class="ml-3">GreenAI</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pt-8 pb-8">
            @* Guard: body only renders after labels are loaded — no raw keys ever visible *@
            @if (_labelsReady)
            {
                @Body
            }
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _labelsReady;

    protected override async Task OnInitializedAsync()
    {
        var languageId = CurrentUser.IsAuthenticated ? CurrentUser.LanguageId : 1;
        await Loc.EnsureLoadedAsync(languageId);
        _labelsReady = true;
    }

    // OnAfterRenderAsync not needed — labels are guarded by @if (_labelsReady) on @Body
}
