@page "/status"
@inject NavigationManager Nav
@inject ILocalizationContext Loc

<AppShell Title='@Loc.Get("page.statusList.Title")' IsLoading="false">

    @* Filter bar *@
    <MudPaper Elevation="0" Class="pa-3 mb-3 mud-paper--outlined" data-testid="status-filter-form">
        <MudGrid Spacing="2" Class="align-items-center">
            <MudItem xs="12" sm="3">
                <MudDatePicker @bind-Date="_filterFrom"
                               Label='@Loc.Get("page.statusList.FilterFrom")'
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               data-testid="filter-from" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudDatePicker @bind-Date="_filterTo"
                               Label='@Loc.Get("page.statusList.FilterTo")'
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               data-testid="filter-to" />
            </MudItem>
            <MudItem xs="12" sm="5">
                <MudTextField @bind-Value="_search"
                              Label='@Loc.Get("page.statusList.FilterSearch")'
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" OnDebounceIntervalElapsed="ApplyFilter"
                              DebounceInterval="350"
                              data-testid="filter-search" />
            </MudItem>
            <MudItem xs="12" sm="1">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Default"
                               title='@Loc.Get("page.statusList.SearchButton")'
                               OnClick="ApplyFilter"
                               data-testid="filter-search-btn" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Tabs: Sent / Scheduled / Failed *@
    <MudTabs Elevation="1" Rounded="true" PanelClass="pt-3"
             @bind-ActivePanelIndex="_activeTab"
             data-testid="status-tabs">

        <MudTabPanel Text='@($"{Loc.Get("page.statusList.StatusSent")} ({_sentResults.Count})")'
                     Icon="@Icons.Material.Filled.CheckCircle"
                     data-testid="tab-sent">
            <BroadcastTable Items="_sentResults" OnRowClick="GoToDetail" Loc="Loc" />
        </MudTabPanel>

        <MudTabPanel Text='@($"{Loc.Get("page.statusList.StatusScheduled")} ({_scheduledResults.Count})")'
                     Icon="@Icons.Material.Filled.Schedule"
                     data-testid="tab-scheduled">
            <BroadcastTable Items="_scheduledResults" OnRowClick="GoToDetail" Loc="Loc" ShowScheduled="true" />
        </MudTabPanel>

        <MudTabPanel Text='@($"{Loc.Get("page.statusList.StatusFailed")} ({_failedResults.Count})")'
                     Icon="@Icons.Material.Filled.Error"
                     data-testid="tab-failed">
            <BroadcastTable Items="_failedResults" OnRowClick="GoToDetail" Loc="Loc" ShowFailed="true" />
        </MudTabPanel>

    </MudTabs>

</AppShell>

@code {
    private int       _activeTab   = 0;
    private DateTime? _filterFrom  = DateTime.Today.AddDays(-30);
    private DateTime? _filterTo;
    private string    _search      = string.Empty;

    private IReadOnlyList<BroadcastMock> _sentResults      = [];
    private IReadOnlyList<BroadcastMock> _scheduledResults = [];
    private IReadOnlyList<BroadcastMock> _failedResults    = [];

    protected override void OnInitialized() => ApplyFilter();

    private void ApplyFilter()
    {
        _sentResults      = FilterByStatus("Sent");
        _scheduledResults = FilterByStatus("Scheduled");
        _failedResults    = FilterByStatus("Failed");
    }

    private IReadOnlyList<BroadcastMock> FilterByStatus(string status)
    {
        var q = MockData.AllBroadcasts.Where(b => b.Status == status);
        if (_filterFrom.HasValue) q = q.Where(b => b.CreatedAt >= _filterFrom.Value);
        if (_filterTo.HasValue)   q = q.Where(b => b.CreatedAt <  _filterTo.Value.AddDays(1));
        if (!string.IsNullOrWhiteSpace(_search))
            q = q.Where(b => b.Subject.Contains(_search, StringComparison.OrdinalIgnoreCase)
                           || b.Profile.Contains(_search, StringComparison.OrdinalIgnoreCase));
        return q.OrderByDescending(b => b.CreatedAt).ToList();
    }

    private void GoToDetail(int id) => Nav.NavigateTo($"/status/{id}");
}
