@page "/counter"

<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h5">Counter</MudText>

<MudText Typo="Typo.body1" role="status" Class="mb-3">Current count: @currentCount</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="IncrementCount" data-testid="counter-increment">Click me</MudButton>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
