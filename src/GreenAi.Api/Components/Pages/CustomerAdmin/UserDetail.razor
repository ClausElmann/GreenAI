@page "/customer-admin/users/{UserId:int}"
@using GreenAi.Api.Features.CustomerAdmin.GetUsers
@using GreenAi.Api.SharedKernel.Auth
@using GreenAi.Api.SharedKernel.Ids
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BlazorPrincipalHolder PrincipalHolder

<PageTitle>Bruger — GreenAi</PageTitle>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" />
    return;
}

@if (_user is null)
{
    <MudAlert Severity="Severity.Warning">Bruger ikke fundet (id: @UserId).</MudAlert>
    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/customer-admin"
               Class="mt-3"
               data-testid="back-to-customer-admin">
        Tilbage til kundestyre
    </MudButton>
    return;
}

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4 px-0" />

<MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
    <MudAvatar Color="Color.Primary">@_user.Email[0]</MudAvatar>
    <div>
        <MudText Typo="Typo.h5">@_user.Email</MudText>
    </div>
    <MudSpacer />
    <MudChip T="string"
             Color="@(_user.IsActive ? Color.Success : Color.Default)"
             Size="Size.Small">
        @(_user.IsActive ? "Aktiv" : "Inaktiv")
    </MudChip>
</MudStack>

<MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">
    <MudTabPanel Text="Profiler" Icon="@Icons.Material.Filled.AccountTree">
        @if (_user.Profiles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Ingen profiler tildelt.</MudText>
        }
        else
        {
            <MudTable Items="_user.Profiles" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Profil</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Profil">
                        <MudLink Href="@("/customer-admin/profiles/" + context.ProfileId)">
                            @context.ProfileName
                        </MudLink>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    <MudTabPanel Text="Roller" Icon="@Icons.Material.Filled.Security">
        @if (_user.Roles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">Ingen roller tildelt.</MudText>
        }
        else
        {
            <MudTable Items="_user.Roles" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Rolle</MudTh>
                    <MudTh>Profil</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Rolle">@context.Role</MudTd>
                    <MudTd DataLabel="Profil">@context.ProfileName</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
</MudTabs>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;
    [Parameter] public int UserId { get; set; }

    private UserDetailsResult? _user;
    private bool _loading = true;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;

        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login");
            return;
        }

        PrincipalHolder.Set(authState.User);

        _loading = true;
        var result = await Mediator.Send(new GetUserDetailsQuery(new UserId(UserId)));
        _user = result.IsSuccess ? result.Value : null;
        _breadcrumbs =
        [
            new("Kundestyre", href: "/customer-admin"),
            new(_user?.Email ?? $"Bruger {UserId}", href: null, disabled: true)
        ];
        _loading = false;
        StateHasChanged();
    }
}
