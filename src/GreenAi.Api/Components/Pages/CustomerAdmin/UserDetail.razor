@page "/customer-admin/users/{UserId:int}"
@using GreenAi.Api.Features.CustomerAdmin.GetUsers
@using GreenAi.Api.SharedKernel.Auth
@using GreenAi.Api.SharedKernel.Ids
@using GreenAi.Api.SharedKernel.Localization
@using Microsoft.AspNetCore.Components.Authorization
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BlazorPrincipalHolder PrincipalHolder
@inject ILocalizationContext Loc

<AppShell Title="@(_user?.Email ?? string.Empty)"
          IsLoading="@_loading"
          ErrorMessage="@_errorMessage"
          Breadcrumbs="_breadcrumbs">

    @if (!_loading && _user is null)
    {
        <MudAlert Severity="Severity.Warning">
            @string.Format(Loc.Get("feature.user.NotFound"), UserId)
        </MudAlert>
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Href="/customer-admin"
                   Class="mt-3"
                   data-testid="back-to-customer-admin">
            @Loc.Get("shared.BackToCustomerAdmin")
        </MudButton>
    }
    else if (_user is not null)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4" Spacing="2">
            <MudAvatar Color="Color.Primary">@_user.Email[0]</MudAvatar>
            <MudSpacer />
            <MudChip T="string"
                     Color="@(_user.IsActive ? Color.Success : Color.Default)"
                     Size="Size.Small"
                     data-testid="user-status-chip">
                @(_user.IsActive ? Loc.Get("shared.Active") : Loc.Get("shared.Inactive"))
            </MudChip>
        </MudStack>

        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4">
    <MudTabPanel Text="@Loc.Get("feature.user.TabProfiles")" Icon="@Icons.Material.Filled.AccountTree">
        @if (_user.Profiles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.Get("feature.user.NoProfilesAssigned")</MudText>
        }
        else
        {
            <MudTable Items="_user.Profiles" Dense="true" Hover="true" data-testid="user-profiles-table">
                <HeaderContent>
                    <MudTh>@Loc.Get("feature.user.ColumnProfile")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Loc.Get("feature.user.ColumnProfile")">
                        <MudLink Href="@("/customer-admin/profiles/" + context.ProfileId)">
                            @context.ProfileName
                        </MudLink>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    <MudTabPanel Text="@Loc.Get("feature.user.TabRoles")" Icon="@Icons.Material.Filled.Security">
        @if (_user.Roles.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.Get("feature.user.NoRolesAssigned")</MudText>
        }
        else
        {
            <MudTable Items="_user.Roles" Dense="true" Hover="true" data-testid="user-roles-table">
                <HeaderContent>
                    <MudTh>@Loc.Get("feature.user.ColumnRole")</MudTh>
                    <MudTh>@Loc.Get("feature.user.ColumnProfile")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Loc.Get("feature.user.ColumnRole")">@context.Role</MudTd>
                    <MudTd DataLabel="@Loc.Get("feature.user.ColumnProfile")">@context.ProfileName</MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>
</MudTabs>
    }

</AppShell>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;
    [Parameter] public int UserId { get; set; }

    private UserDetailsResult? _user;
    private bool _loading = true;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;

        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login");
            return;
        }

        PrincipalHolder.Set(authState.User);

        _loading = true;
        var result = await Mediator.Send(new GetUserDetailsQuery(new UserId(UserId)));
        if (!result.IsSuccess)
        {
            _errorMessage = result.Error!.Message;
            _loading      = false;
            StateHasChanged();
            return;
        }
        _user = result.Value;
        _breadcrumbs =
        [
            new(Loc.Get("nav.CustomerAdmin"), href: "/customer-admin"),
            new(_user?.Email ?? string.Format(Loc.Get("feature.user.BreadcrumbDefault"), UserId), href: null, disabled: true)
        ];
        _loading = false;
        StateHasChanged();
    }
}
