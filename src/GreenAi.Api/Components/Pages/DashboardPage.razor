@page "/dashboard"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject ILocalizationContext Loc

<AppShell Title="@Loc.Get("nav.Home")" IsLoading="false">

    @* ── Quick actions ────────────────────────────────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-2" data-testid="dashboard-placeholder">
        <MudItem xs="12">
            <MudText Typo="Typo.overline" Class="mud-text-secondary dashboard-section-label">@Loc.Get("dashboard.QuickActions")</MudText>
            <div class="dashboard-actions">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Send"
                           Href="/send/wizard"
                           data-testid="dashboard-action-send">
                    @Loc.Get("nav.Send")
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           Href="/status"
                           data-testid="dashboard-action-status">
                    @Loc.Get("nav.Status")
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Edit"
                           Href="/drafts"
                           data-testid="dashboard-action-drafts">
                    @Loc.Get("nav.Drafts")
                </MudButton>
            </div>
        </MudItem>
    </MudGrid>

    @* ── Metrics row ──────────────────────────────────────────────────────── *@
    <MudGrid Spacing="2" Class="mb-2">
        <MudItem xs="12">
            <MudText Typo="Typo.overline" Class="mud-text-secondary dashboard-section-label">@Loc.Get("dashboard.SectionMetrics")</MudText>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="1" Class="dashboard-metric-card" data-testid="metric-messages-today">
                <MudCardContent Class="pa-3">
                    <div class="metric-icon-row">
                        <MudIcon Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">@Loc.Get("dashboard.MetricMessagesToday")</MudText>
                    </div>
                    <MudText Typo="Typo.h4" Class="metric-value mt-1">@MockData.KpiMessagesToday.ToString("N0")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="1" Class="dashboard-metric-card" data-testid="metric-failed">
                <MudCardContent Class="pa-3">
                    <div class="metric-icon-row">
                        <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">@Loc.Get("dashboard.MetricFailed")</MudText>
                    </div>
                    <MudText Typo="Typo.h4" Class="metric-value mt-1" Style="color:var(--mud-palette-error)">@MockData.KpiFailed.ToString("N0")</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="1" Class="dashboard-metric-card" data-testid="metric-active-profiles">
                <MudCardContent Class="pa-3">
                    <div class="metric-icon-row">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Success" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">@Loc.Get("dashboard.MetricActiveProfiles")</MudText>
                    </div>
                    <MudText Typo="Typo.h4" Class="metric-value mt-1" Style="color:var(--mud-palette-success)">@MockData.KpiActiveProfiles</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Elevation="1" Class="dashboard-metric-card" data-testid="metric-drafts">
                <MudCardContent Class="pa-3">
                    <div class="metric-icon-row">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Medium" />
                        <MudText Typo="Typo.caption" Class="mud-text-secondary ml-1">@Loc.Get("dashboard.MetricDrafts")</MudText>
                    </div>
                    <MudText Typo="Typo.h4" Class="metric-value mt-1">@MockData.KpiDrafts</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* ── Activity + Info ──────────────────────────────────────────────────── *@
    <MudGrid Spacing="2">
        <MudItem xs="12">
            <MudText Typo="Typo.overline" Class="mud-text-secondary dashboard-section-label">@Loc.Get("dashboard.SectionActivity")</MudText>
        </MudItem>
        <MudItem xs="12" md="8">
            <MudCard Elevation="1" data-testid="dashboard-activity">
                <MudCardHeader Class="pb-0 pt-3 px-3">
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1"><b>@Loc.Get("dashboard.RecentActivity")</b></MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudLink Href="/status" Typo="Typo.caption">@Loc.Get("dashboard.ViewAll") →</MudLink>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudList T="string" Dense="true" Class="pt-0">
                        @foreach (var item in MockData.Activities)
                        {
                            <MudListItem Dense="true" Class="px-3 py-2">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="flex-nowrap">
                                    <MudIcon Icon="@GetActivityIcon(item.Severity)"
                                             Color="@GetActivityColor(item.Severity)"
                                             Size="Size.Small"
                                             Style="flex-shrink:0" />
                                    <div Style="min-width:0;flex:1">
                                        <MudText Typo="Typo.body2">
                                            <b>@item.Action</b> · @item.Subject
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @item.Profile · @FormatRelativeTime(item.At)
                                        </MudText>
                                    </div>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudCard Elevation="1" data-testid="dashboard-info">
                <MudCardHeader Class="pb-0 pt-3 px-3">
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1"><b>@Loc.Get("dashboard.QuickInfo")</b></MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-3">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.Get("page.home.CustomerAdminDescription")</MudText>
                    <MudDivider Class="my-3" />
                    <MudLink Href="/customer-admin" Typo="Typo.body2" data-testid="dashboard-link-customer-admin">
                        @Loc.Get("shared.BackToCustomerAdmin") →
                    </MudLink>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

</AppShell>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true)
            Nav.NavigateTo("/login");
    }

    private static string GetActivityIcon(string severity) => severity switch
    {
        "success" => Icons.Material.Filled.CheckCircle,
        "error"   => Icons.Material.Filled.Error,
        "warning" => Icons.Material.Filled.Warning,
        _         => Icons.Material.Filled.Info,
    };

    private static Color GetActivityColor(string severity) => severity switch
    {
        "success" => Color.Success,
        "error"   => Color.Error,
        "warning" => Color.Warning,
        _         => Color.Info,
    };

    private static string FormatRelativeTime(DateTime at)
    {
        var diff = DateTime.Now - at;
        if (diff.TotalMinutes < 2)   return "lige nu";
        if (diff.TotalMinutes < 60)  return $"for {(int)diff.TotalMinutes} min. siden";
        if (diff.TotalHours   < 24)  return $"for {(int)diff.TotalHours} t. siden";
        if (diff.TotalDays    < 7)   return $"for {(int)diff.TotalDays} d. siden";
        return at.ToString("d. MMM");
    }
}
