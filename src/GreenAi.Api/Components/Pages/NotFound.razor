@page "/not-found"
@layout MainLayout
@inject ILocalizationContext Loc

<AppShell Title='@Loc.Get("page.notFound.Title")' IsLoading="false">
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @Loc.Get("page.notFound.Message")
    </MudAlert>
    <MudButton Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Home"
               Href="/"
               data-testid="not-found-home-btn">
        @Loc.Get("page.notFound.BackHome")
    </MudButton>
</AppShell>