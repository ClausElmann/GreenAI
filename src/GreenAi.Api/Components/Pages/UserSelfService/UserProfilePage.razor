@page "/user/profile"
@using GreenAi.Api.Features.Auth.Me
@using GreenAi.Api.Features.UserSelfService.UpdateUser
@using Microsoft.AspNetCore.Components.Authorization
@using GreenAi.Api.SharedKernel.Auth
@inject IMediator Mediator
@inject NavigationManager Nav
@inject BlazorPrincipalHolder PrincipalHolder
@inject ILocalizationContext Loc
@inject ICurrentUser CurrentUser

<AppShell Title="@Loc.Get("feature.userProfile.Title")"
          IsLoading="@_loading"
          ErrorMessage="@_errorMessage">

    @* ── Account section ──────────────────────────────────────────────────── *@
    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-2 d-block">
        @Loc.Get("feature.userProfile.AccountSection")
    </MudText>

    <MudGrid Spacing="3" Class="mb-4 px-2 px-sm-0">
        <MudItem xs="12" sm="6">
            <MudTextField Value="@_email"
                          Label="@Loc.Get("shared.EmailLabel")"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          data-testid="email-display" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_displayName"
                          Label="@Loc.Get("feature.userProfile.DisplayNameLabel")"
                          Variant="Variant.Outlined"
                          data-testid="display-name-input" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField Value="@_role"
                          Label="@Loc.Get("feature.userProfile.RoleLabel")"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          data-testid="role-display" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField Value="@_memberSince"
                          Label="@Loc.Get("feature.userProfile.MemberSince")"
                          Variant="Variant.Outlined"
                          ReadOnly="true"
                          data-testid="member-since-display" />
        </MudItem>
    </MudGrid>

    @* ── Preferences section ──────────────────────────────────────────────── *@
    <MudText Typo="Typo.overline" Color="Color.Secondary" Class="mb-2 d-block">
        @Loc.Get("feature.userProfile.PreferencesSection")
    </MudText>

    <MudGrid Spacing="3" Class="mb-4 px-2 px-sm-0">
        <MudItem xs="12" sm="6">
            <MudSelect @bind-Value="_languageId"
                       Label="@Loc.Get("feature.userProfile.LanguageLabel")"
                       Variant="Variant.Outlined"
                       data-testid="language-select">
                <MudSelectItem Value="1">@Loc.Get("feature.userProfile.LanguageDanish")</MudSelectItem>
                <MudSelectItem Value="2">@Loc.Get("feature.userProfile.LanguageEnglish")</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>

    @* ── Actions ──────────────────────────────────────────────────────────── *@
    <MudStack Row="true" Spacing="2" Class="px-2 px-sm-0">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SaveAsync"
                   data-testid="save-profile-button">
            @Loc.Get("feature.userProfile.SaveButton")
        </MudButton>
    </MudStack>

    @if (_saveSuccess)
    {
        <MudAlert Severity="Severity.Success" Class="mt-3 mx-2 mx-sm-0" data-testid="save-success-alert">
            @Loc.Get("feature.userProfile.SaveSuccess")
        </MudAlert>
    }

</AppShell>

@code {
    [CascadingParameter] private Task<AuthenticationState> AuthStateTask { get; set; } = null!;

    private bool    _loading     = true;
    private string  _email       = string.Empty;
    private string  _displayName = string.Empty;
    private string  _role        = string.Empty;
    private string  _memberSince = string.Empty;
    private int     _languageId  = 1;
    private string? _errorMessage;
    private bool    _saveSuccess;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login");
            return;
        }

        PrincipalHolder.Set(authState.User);

        // Load email from backend; fall back to current principal claim on failure
        var result = await Mediator.Send(new MeQuery());
        if (result.IsSuccess)
            _email = result.Value!.Email;
        else
            _email = authState.User.Identity?.Name ?? CurrentUser.Email;

        // Use JWT claims for fields not yet backed by real handlers
        _displayName = authState.User.Claims
                           .FirstOrDefault(c => c.Type == "name" || c.Type == "display_name")
                           ?.Value
                       ?? _email.Split('@')[0];
        _role        = authState.User.Claims
                           .FirstOrDefault(c => c.Type == "role" || c.Type is
                               "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")
                           ?.Value ?? "User";
        _memberSince = authState.User.Claims
                           .FirstOrDefault(c => c.Type == "created_at")
                           ?.Value is { } ts && DateTime.TryParse(ts, out var dt)
                       ? dt.ToString("d. MMM yyyy")
                       : DateTime.Now.AddMonths(-3).ToString("d. MMM yyyy");

        _loading = false;
        StateHasChanged();
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        _saveSuccess  = false;

        var result = await Mediator.Send(new UpdateUserCommand(_displayName, null));

        if (!result.IsSuccess)
            _errorMessage = result.Error!.Message;
        else
            _saveSuccess = true;

        StateHasChanged();
    }
}
