@page "/login"
@layout EmptyLayout
@using GreenAi.Api.Components.Layout
@using GreenAi.Api.Features.Auth.Login
@using GreenAi.Api.SharedKernel.Auth
@using GreenAi.Api.SharedKernel.Localization
@using GreenAi.Api.SharedKernel.State
@using MediatR
@using MudBlazor
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject GreenAiAuthenticationStateProvider AuthProvider
@inject IMediator Mediator
@inject NavigationManager Nav
@inject ILocalizationContext Loc
@inject AppState AppState
@inject JwtTokenService JwtTokenService
@inject BlazorPrincipalHolder PrincipalHolder

<PageTitle>Log ind — GreenAi</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="pt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">@Loc.Get("auth.Login.Title")</MudText>

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_model.Email"
                          Label="@Loc.Get("shared.EmailLabel")"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Margin="Margin.Dense"
                          Class="mb-4"
                          UserAttributes="@(new Dictionary<string, object>{ ["data-testid"] = "login-email" })"
                          Disabled="_loading" />

            <MudTextField @bind-Value="_model.Password"
                          Label="@Loc.Get("auth.Login.PasswordLabel")"
                          Variant="Variant.Outlined"
                          InputType="_showPassword ? InputType.Text : InputType.Password"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showPassword = !_showPassword"
                          Margin="Margin.Dense"
                          Class="mb-2"
                          UserAttributes="@(new Dictionary<string, object>{ ["data-testid"] = "login-password" })"
                          Disabled="_loading" />

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="_loading"
                       data-testid="login-submit"
                       Class="mt-2">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>@Loc.Get("auth.Login.Loading")</span>
                }
                else
                {
                    <span>@Loc.Get("auth.Login.SubmitButton")</span>
                }
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@* Blazor circuit readiness marker — only rendered after OnAfterRenderAsync.
   Tests wait for this element before interacting so they know event handlers are wired. *@
@if (_circuitReady)
{
    <span id="blazor-circuit-ready" style="display:none" data-testid="blazor-circuit-ready"></span>
}

@code {
    private readonly LoginModel _model = new();
    private bool _loading;
    private bool _showPassword;
    private string? _errorMessage;
    private bool _circuitReady;

    protected override async Task OnInitializedAsync()
    {
        // Login page uses EmptyLayout (no MainLayout), so labels must be loaded here.
        await Loc.EnsureLoadedAsync(1); // Default Danish — user not authenticated yet
    }

    // OnAfterRenderAsync fires ONLY via the Blazor circuit (never during SSR pre-render).
    // Setting _circuitReady here gives tests a reliable DOM marker to wait for before
    // interacting, ensuring @bind-Value and form event handlers are fully wired.
    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_circuitReady)
        {
            _circuitReady = true;
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private async Task HandleLoginAsync()
    {
        _loading = true;
        _errorMessage = null;

        try
        {
            var result = await Mediator.Send(new LoginCommand(_model.Email, _model.Password));

            if (!result.IsSuccess)
            {
                _errorMessage = result.Error!.Message;
                return;
            }

            if (result.Value!.NeedsCustomerSelection)
            {
                // Multiple customers — set pre-auth principal so select-customer page can call Mediator
                var preAuthPrincipal = JwtTokenService.ValidateToken(result.Value.PreAuthToken!);
                if (preAuthPrincipal is not null)
                    PrincipalHolder.Set(preAuthPrincipal);
                AppState.SetPendingCustomers(result.Value.AvailableCustomers?.ToList() ?? []);
                Nav.NavigateTo("/select-customer");
                return;
            }

            if (result.Value.NeedsProfileSelection)
            {
                // Single customer, multiple profiles — set pre-auth principal so select-profile page can call Mediator
                var preAuthPrincipal = JwtTokenService.ValidateToken(result.Value.PreAuthToken!);
                if (preAuthPrincipal is not null)
                    PrincipalHolder.Set(preAuthPrincipal);
                AppState.SetPendingProfiles(result.Value.AvailableProfiles?.ToList() ?? []);
                Nav.NavigateTo("/select-profile");
                return;
            }

            await AuthProvider.SignInAsync(
                result.Value.AccessToken,
                result.Value.RefreshToken,
                result.Value.ExpiresAt);

            // Set PrincipalHolder so ICurrentUser.IsAuthenticated is true when Home.razor
            // renders synchronously on navigation — localStorage-backed auth state is async
            // and may not have propagated yet when the circuit navigates to the next route.
            var fullPrincipal = JwtTokenService.ValidateToken(result.Value.AccessToken!);
            if (fullPrincipal is not null)
                PrincipalHolder.Set(fullPrincipal);

            Nav.NavigateTo("/broadcasting");
        }
        finally
        {
            _loading = false;
        }
    }

    private sealed class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
